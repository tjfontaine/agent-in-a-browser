{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "rootDir": "src",
        "declaration": true,
        "sourceMap": true,
        "lib": [
            "ES2022"
        ],
        "paths": {
            "@tjfontaine/edge-agent-session": [
                "../edge-agent-session/src/index.ts"
            ],
            "@tjfontaine/edge-agent-session/*": [
                "../edge-agent-session/src/*"
            ]
        },
        "composite": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "references": [
        {
            "path": "../edge-agent-session"
        }
    ]
}
