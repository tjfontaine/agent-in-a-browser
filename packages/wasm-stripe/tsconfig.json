{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "paths": {
            "@tjfontaine/wasm-loader": [
                "../wasm-loader/src/index.ts"
            ],
            "@tjfontaine/wasm-loader/*": [
                "../wasm-loader/src/*"
            ]
        },
        "composite": true
    },
    "include": [
        "src"
    ],
    "references": [
        {
            "path": "../wasm-loader"
        }
    ]
}
