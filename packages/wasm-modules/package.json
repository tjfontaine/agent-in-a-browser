{
    "name": "@tjfontaine/wasm-modules",
    "version": "0.1.0",
    "description": "Aggregator package that re-exports all WASM module metadata",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@tjfontaine/wasm-loader": "workspace:*",
        "@tjfontaine/wasm-tsx": "workspace:*",
        "@tjfontaine/wasm-sqlite": "workspace:*",
        "@tjfontaine/wasm-ratatui": "workspace:*",
        "@tjfontaine/wasm-vim": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.7.0"
    }
}
