{
    "name": "@tjfontaine/mcp-wasm-server",
    "version": "0.1.0",
    "type": "module",
    "description": "MCP (Model Context Protocol) server with prebuilt WASM runtime",
    "main": "dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./mcp-server-jspi/*": "./mcp-server-jspi/*",
        "./mcp-server-sync/*": "./mcp-server-sync/*"
    },
    "files": [
        "dist",
        "wasm",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist mcp-server-jspi mcp-server-sync",
        "test": "vitest run"
    },
    "dependencies": {
        "@tjfontaine/wasi-shims": "workspace:*"
    },
    "peerDependencies": {},
    "devDependencies": {
        "typescript": "^5.7.0",
        "vitest": "^4.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/tjfontaine/web-agent.git",
        "directory": "packages/mcp-wasm-server"
    },
    "license": "MIT"
}