{
  "name": "web-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "moon run :build :transpile :transpile-sync",
    "build:wasm": "moon run runtime:build-wasm",
    "build:frontend": "moon run frontend:build frontend:copy-externals",
    "dev": "concurrently -n wasm,frontend -c yellow,cyan 'pnpm:dev:wasm' 'pnpm:dev:frontend'",
    "dev:wasm": "cargo watch -w runtime/src -s 'cargo component build --release --target wasm32-wasip2 --manifest-path runtime/Cargo.toml'",
    "dev:frontend": "moon run frontend:dev",
    "clean": "cargo clean && moon run :clean",
    "test": "moon run :test",
    "docker:build": "docker build -t web-agent .",
    "docker:run": "docker run -p 8080:8080 web-agent"
  },
  "devDependencies": {
    "@moonrepo/cli": "^2.0.4",
    "concurrently": "^9.2.1",
    "esbuild": "^0.20.0"
  },
  "engines": {
    "node": "22.22.0"
  }
}
